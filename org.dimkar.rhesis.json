{
  "id": "org.dimkar.rhesis",
  "runtime": "org.kde.Platform",
  "runtime-version": "6.9",
  "sdk": "org.kde.Sdk",
  "command": "rhesis",
  "desktop-file-name-suffix": "",
  "sdk-extensions": [
    "org.freedesktop.Sdk.Extension.rust-stable",
    "org.freedesktop.Sdk.Extension.openjdk17"
  ],
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin"
  },
  "finish-args": [
    "--share=ipc",
    "--device=dri",
    "--socket=fallback-x11",
    "--socket=wayland"
  ],
  "modules": [
    {
      "name": "mold",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm755 bin/mold /app/bin/mold",
        "install -Dm755 bin/ld.mold /app/bin/ld.mold"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://github.com/rui314/mold/releases/download/v2.41.0/mold-2.41.0-x86_64-linux.tar.gz",
          "sha256": "a3696680d99e692970590a178bc3a33d78d60d1c6dc9db7a11b557b02b751f5d"
        }
      ]
    },
    {
      "buildsystem": "cmake",
      "name": "corrosion",
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/corrosion-rs/corrosion.git",
          "tag": "v0.6.1"
        }
      ]
    },
    {
      "buildsystem": "simple",
      "name": "openjdk",
      "build-commands": [
        "/usr/lib/sdk/openjdk17/installjdk.sh"
      ]
    },
    {
      "buildsystem": "simple",
      "name": "rhesis",
      "build-options": {
        "env": {
          "CARGO_HOME": "/run/build/rhesis/cargo"
        }
      },
      "build-commands": [
        "cmake -DCMAKE_INSTALL_PREFIX=/app .",
        "make -j$(nproc) install",
        "install -Dm644 org.dimkar.rhesis.png /app/share/icons/hicolor/256x256/apps/org.dimkar.rhesis.png",
        "cp -r LanguageTool /app/",
        "cp -r fastText /app/",
        "cp lid.176.bin /app/",
        "ln -s /app/jdk/bin/java /app/bin/java"
      ],
      "sources": [
        "build/cargo-sources.json",
        {
          "type": "dir",
          "path": "."
        }
      ]
    }
  ]
}
